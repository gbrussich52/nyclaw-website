# NYClaw.io environment variables
# Copy to .env.local for local dev. Production values live in the Vercel dashboard.
# NEVER commit real values.

# --- Lead notifications (required — validated by lib/env.ts) ---
GMAIL_USER=
GMAIL_APP_PASSWORD=
NOTIFY_EMAIL=

# --- Google Sheets lead log (required — validated by lib/env.ts) ---
# Full service-account JSON as a single line
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEET_ID=

# --- Distributed rate limiting (optional — lib/rate-limit.ts) ---
# Upstash Redis REST credentials. When BOTH are set, rate limiting is shared
# across all Vercel instances; when unset, a per-instance in-memory fallback
# is used (functional but weak under serverless scale-out).
#
# Provisioned 2026-06-10 via Vercel Marketplace "Upstash KV" (resource:
# upstash-kv-teal-house). The integration injects KV_REST_API_URL and
# KV_REST_API_TOKEN into all environments; the limiter accepts either naming
# convention. Env vars are not hot-reloaded — redeploy after changes.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Direct-Upstash alternative names (take precedence if both are set):
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
